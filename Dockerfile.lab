FROM python:3.12-slim

WORKDIR /app
RUN mkdir -p /data

# Install Akad core (workers and clients only — no registry/dashboard server deps)
COPY pyproject.toml ./
COPY akad/ ./akad/
COPY registry/ ./registry/
COPY dashboard/ ./dashboard/
RUN pip install --no-cache-dir -e "."

# Copy lab scripts and contracts
COPY lab/ /lab/

CMD ["python", "/lab/demo.py"]
